# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# The single allowed email for this personal instance.
ALLOWED_USER_EMAIL=

# --- AI provider ---
# Provider is undecided as of Phase 0. Populate whichever is chosen before
# building AI features in Phase 1+. Keep only one provider's keys in use.
AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional local model fallback (see PLAN.md section 4)
OLLAMA_BASE_URL=

# --- Google (Phase 3) ---
# Create an OAuth client (Web application) in Google Cloud Console with the
# Calendar API enabled. Redirect URI must exactly match GOOGLE_REDIRECT_URI,
# e.g. http://localhost:3000/api/google/callback in development.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Token encryption (Phase 3) ---
# 32-byte key, base64-encoded, used for AES-256-GCM encryption of provider
# OAuth tokens at rest. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Web push (Phase 3) ---
# VAPID keypair for browser push notifications. Generate with:
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact address Google/browser push services may use to reach you about this key.
VAPID_SUBJECT=mailto:you@example.com

# --- Recruiting discovery cron (Phase 5) ---
# Bearer token Vercel Cron sends to /api/cron/discover-jobs and
# /api/cron/weekly-digest. Vercel automatically sends this as
# `Authorization: Bearer $CRON_SECRET` for scheduled invocations of routes
# when this env var is set. Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Canvas (Phase 6+) ---
CANVAS_BASE_URL=
CANVAS_PERSONAL_ACCESS_TOKEN=

# --- Gmail (Phase 7) ---
# Reuses the GOOGLE_CLIENT_ID/SECRET above (same registered OAuth app) — add
# the Gmail API and its own redirect URI as an additional authorized
# redirect in the same Google Cloud Console client, e.g.
# http://localhost:3000/api/gmail/callback in development. Gmail is expected
# to be a *different* Google account than the one connected for Calendar
# (task 7.1), which is exactly why this needs its own callback/redirect URI
# rather than reusing GOOGLE_REDIRECT_URI.
GMAIL_REDIRECT_URI=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
