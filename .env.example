# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# The single allowed email for this personal instance.
ALLOWED_USER_EMAIL=

# --- AI provider ---
# Gemini is the configured provider (docs/DECISIONS/0002-gemini-ai-provider.md).
# Get a key at https://aistudio.google.com/apikey. Both values are required
# to activate AI extraction (Inbox, syllabus, Gmail) — either one missing
# leaves getAIClient() returning null and those features hidden.
AI_PROVIDER=gemini
GEMINI_API_KEY=
# Optional (docs/DECISIONS/0003-groq-for-gmail-extraction.md). Gmail
# extraction uses Groq instead of the provider above when this is set — get
# a key at https://console.groq.com/keys. Leave unset to keep Gmail
# extraction on Gemini too.
GROQ_API_KEY=
# Optional local model fallback for dev/experimentation (see PLAN.md §4, §18)
OLLAMA_BASE_URL=
# Optional (Phase 8). Daily cap on chat input+output tokens per PLAN.md §4's
# "per-feature daily token and dollar limits". Defaults to 200000 if unset —
# not required for chat to work.
AI_CHAT_DAILY_TOKEN_LIMIT=

# --- Google (Phase 3) ---
# Create an OAuth client (Web application) in Google Cloud Console with the
# Calendar API enabled. Redirect URI must exactly match GOOGLE_REDIRECT_URI,
# e.g. http://localhost:3000/api/google/callback in development.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Token encryption (Phase 3) ---
# 32-byte key, base64-encoded, used for AES-256-GCM encryption of provider
# OAuth tokens at rest. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Web push (Phase 3) ---
# VAPID keypair for browser push notifications. Generate with:
# npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact address Google/browser push services may use to reach you about this key.
VAPID_SUBJECT=mailto:you@example.com

# --- Recruiting discovery cron (Phase 5) ---
# Bearer token Vercel Cron sends to /api/cron/discover-jobs and
# /api/cron/weekly-digest. Vercel automatically sends this as
# `Authorization: Bearer $CRON_SECRET` for scheduled invocations of routes
# when this env var is set. Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Canvas (Phase 6+) ---
CANVAS_BASE_URL=
CANVAS_PERSONAL_ACCESS_TOKEN=

# --- Gmail (Phase 7) ---
# Its own OAuth client (Web application) in Google Cloud Console, separate
# from the Calendar one above — with the Gmail API enabled. Redirect URI
# must exactly match GMAIL_REDIRECT_URI, e.g.
# http://localhost:3000/api/gmail/callback in development. Gmail is expected
# to be a *different* Google account than the one connected for Calendar
# (task 7.1).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
