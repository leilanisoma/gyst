# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# The single allowed email for this personal instance.
ALLOWED_USER_EMAIL=

# --- AI provider ---
# Provider is undecided as of Phase 0. Populate whichever is chosen before
# building AI features in Phase 1+. Keep only one provider's keys in use.
AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional local model fallback (see PLAN.md section 4)
OLLAMA_BASE_URL=

# --- Google (Phase 3+) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Canvas (Phase 6+) ---
CANVAS_BASE_URL=
CANVAS_PERSONAL_ACCESS_TOKEN=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
